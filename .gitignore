/target
Cargo.lock
testdata/expected-tokens.tsv
testdata/expected-parse.jsonl
tools/out/
*.class

# Cross-validation artifacts generated by scripts/cross-validate.sh (Phase 2 Task 3): one
# <corpus>.java.jsonl / <corpus>.rust.jsonl pair per testdata/<corpus>.txt corpus. Regenerated
# on every run; the corpora themselves (testdata/*.txt) ARE tracked.
testdata/*.java.jsonl
testdata/*.rust.jsonl

# Maven build output for bindings/java (and later bindings/java/jmh) — the root /target
# above only covers the Cargo workspace target dir, not Maven modules under bindings/.
bindings/**/target/
# Per-platform cdylibs staged by ci/build-cdylib.sh for the Java classifier JARs (built, not tracked)
bindings/java/native-staging/

# IDE
/.idea/
# Eclipse / jdtls (Java LSP) generated project files
bindings/java/.classpath
bindings/java/.project
bindings/java/.settings/

# subagent-driven-development scratch (briefs, reports, ledger)
/.superpowers/

# Large real-world corpora dropped into testdata/ (colxr26.6 8M, clb-verbatim 67M, clb-names-parsed 41M — 6.85 GB). NEVER commit.
testdata/*.tsv

# Phase 4a: project-local Python venv used to build/test crates/nameparser-py via maturin.
# Never commit a venv or a built wheel (target/wheels/ is already covered by /target above).
/.venv/

# Phase 4a: pytest/CPython bytecode-cache artifacts generated under crates/nameparser-py/python/
# by every `pytest` run — never source, regenerated locally on demand.
__pycache__/
*.pyc
.pytest_cache/

# Large derived name corpora (concatenated full-name .txt, hundreds of MB) — never commit
testdata/col*.txt

# Phase 4b: R/extendr package build artifacts (bindings/**/target already covers the cargo dir)
bindings/r/src/*.o
bindings/r/src/*.so
bindings/r/src/rust/target/
bindings/r/*.Rcheck/
bindings/r/**/*.rds
