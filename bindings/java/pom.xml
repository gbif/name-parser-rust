<?xml version="1.0" encoding="UTF-8"?>
<!-- SPDX-License-Identifier: Apache-2.0 -->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <!--
    Standalone FOR NOW: no GBIF <parent> motherpom yet, because motherpom enforces
    `maven.compiler.release=17`, which rejects `java.lang.foreign` (FFM/Panama) source (this
    module needs release 22 — java.lang.foreign is finalized/stable as of JDK 22).
    THE PLAN: this module rides the 4.x name-parser reactor version (see <version>) as the
    Rust-backed implementation of name-parser-api, and eventually MOVES INTO the name-parser
    reactor once that reactor moves to Java 22+ (the Phase-5 backend-cutover prerequisite). At
    that point it inherits motherpom (parent, distributionManagement, release plugins) and the
    standalone <repositories>/<distributionManagement> below become redundant. The Rust ENGINE
    it wraps (gbif-name-parser on crates.io + the PyPI/CRAN bindings) keeps its OWN independent
    semver — only this JVM adapter tracks the reactor line.
  -->
  <groupId>org.gbif.nameparser</groupId>
  <artifactId>name-parser-rust</artifactId>
  <version>4.2.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>GBIF Name Parser :: Rust FFM binding</name>
  <description>
    org.gbif.nameparser.rust.NameParserRust implements org.gbif.nameparser.api.NameParser by
    downcalling the nameparser-ffi Rust cdylib (crates/nameparser-ffi, this repo) over
    java.lang.foreign (FFM/Panama). Two wire formats (JSON, STRUCT) selected via WireFormat;
    see bindings/java/README.md.
  </description>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>22</maven.compiler.release>

    <!-- Resolution order actually used at runtime (see Ffi.resolveLibPath): the system
         property below (as passed by the surefire argLine) -> env NAMEPARSER_FFI_LIB ->
         a repo-relative default hardcoded in Ffi.java. This property exists so `mvn test`
         has a working default without the caller having to set anything, and so the
         Linux profile below can override just this one coordinate. -->
    <nameparser.ffi.lib>${project.basedir}/../../target/release/libnameparser_ffi.dylib</nameparser.ffi.lib>

    <!-- Same idea as nameparser.ffi.lib above, for ParityTest's corpus discovery
         (ParityTest.testdataDir()): an absolute default so `mvn test` works regardless of
         surefire's working directory, with the module-relative "../../testdata" as ParityTest's
         own fallback if this property is ever unset (e.g. run directly from an IDE). -->
    <nameparser.testdata.dir>${project.basedir}/../../testdata</nameparser.testdata.dir>
  </properties>

  <dependencies>
    <!-- The oracle model/interfaces: ParsedName, NameParser, UnparsableNameException, the enums.
         Released 4.2.0 (resolvable from repository.gbif.org via the <repositories> block below;
         also cached in ~/.m2) — see bindings/java/README.md. -->
    <dependency>
      <groupId>org.gbif</groupId>
      <artifactId>name-parser-api</artifactId>
      <version>4.2.0</version>
    </dependency>

    <!-- The JSON wire format: GSON.fromJson(json, ParsedName.class) reflectively rebuilds
         ParsedName field-by-field, bypassing the side-effecting setters — see
         NameParserRust's class doc. -->
    <dependency>
      <groupId>com.google.code.gson</groupId>
      <artifactId>gson</artifactId>
      <version>2.11.0</version>
    </dependency>

    <!-- Test-only: the Java oracle implementation, for future parity testing
         (bindings/java's ParityTest) against this JSON-over-FFM path. Not used by the
         smoke test itself. -->
    <dependency>
      <groupId>org.gbif</groupId>
      <artifactId>name-parser</artifactId>
      <version>4.2.0</version>
      <scope>test</scope>
    </dependency>

    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.10.2</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <!-- Resolve org.gbif deps (name-parser-api / name-parser) from GBIF's Nexus, since this
       standalone POM has no motherpom to supply them. -->
  <repositories>
    <repository>
      <id>gbif-all</id>
      <url>https://repository.gbif.org/content/groups/gbif</url>
    </repository>
  </repositories>

  <!-- INTERIM `mvn deploy` targets (GBIF Nexus) — used only while this module is standalone;
       once it joins the name-parser reactor, motherpom supplies these. The <id>s MUST match
       <server> credential entries in the deployer's ~/.m2/settings.xml — adjust
       `gbif-release`/`gbif-snapshot` to your actual server ids. This 4.2.0-SNAPSHOT deploys to
       the snapshot repo (re-deployable); a 4.2.0 release goes to the release repo. -->
  <distributionManagement>
    <repository>
      <id>gbif-release</id>
      <url>https://repository.gbif.org/content/repositories/releases/</url>
    </repository>
    <snapshotRepository>
      <id>gbif-snapshot</id>
      <url>https://repository.gbif.org/content/repositories/snapshots/</url>
    </snapshotRepository>
  </distributionManagement>

  <build>
    <!-- os-maven-plugin exposes ${os.detected.classifier} (e.g. osx-aarch_64, linux-x86_64),
         used below to place the bundled cdylib under native/<classifier>/, matching
         Ffi.osDetectedClassifier() at load time. -->
    <extensions>
      <extension>
        <groupId>kr.motd.maven</groupId>
        <artifactId>os-maven-plugin</artifactId>
        <version>1.7.1</version>
      </extension>
    </extensions>

    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
      </plugin>

      <!-- Make the JAR self-contained: copy the nameparser-ffi cdylib into
           target/classes/native/${os.detected.classifier}/ at prepare-package so it ships inside
           the JAR (Ffi extracts it at load time). Requires the cdylib to be release-built first
           (`cargo build -p nameparser-ffi`, release profile). In CI the Jenkins matrix additionally
           stashes every platform's cdylib into
           src/main/resources/native/** for a multi-platform JAR; the two paths coexist. If no
           cdylib is present the copy is a no-op and Ffi falls back to -D/env or the dev path. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-antrun-plugin</artifactId>
        <version>3.1.0</version>
        <executions>
          <execution>
            <id>bundle-native-cdylib</id>
            <phase>prepare-package</phase>
            <goals><goal>run</goal></goals>
            <configuration>
              <target>
                <mkdir dir="${project.build.outputDirectory}/native/${os.detected.classifier}"/>
                <copy todir="${project.build.outputDirectory}/native/${os.detected.classifier}"
                      flatten="true" overwrite="true" failonerror="false">
                  <fileset dir="${project.basedir}/../../target/release" erroronmissingdir="false">
                    <include name="libnameparser_ffi.so"/>
                    <include name="libnameparser_ffi.dylib"/>
                    <include name="nameparser_ffi.dll"/>
                  </fileset>
                </copy>
              </target>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.2.5</version>
        <configuration>
          <!-- FFM downcalls are a JDK "restricted method": without opting in to native
               access the JVM only warns today, but a future JDK release blocks it
               outright, so the test JVM opts in explicitly for the unnamed module (this
               module has no module-info.java). The nameparser.ffi.lib system property
               threads the resolved cdylib path (see the property above / the
               linux-cdylib profile below) into the forked test JVM, where
               Ffi.resolveLibPath() reads it. -->
          <argLine>--enable-native-access=ALL-UNNAMED -Dnameparser.ffi.lib=${nameparser.ffi.lib} -Dnameparser.testdata.dir=${nameparser.testdata.dir}</argLine>
        </configuration>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <!-- macOS (this module's dev target) is covered by the default
         <nameparser.ffi.lib> property above (a .dylib path). This profile only
         overrides the file extension for a Linux CI/dev box; the resolution logic
         itself (Ffi.resolveLibPath) is OS-agnostic. -->
    <profile>
      <id>linux-cdylib</id>
      <activation>
        <os>
          <family>unix</family>
          <name>Linux</name>
        </os>
      </activation>
      <properties>
        <nameparser.ffi.lib>${project.basedir}/../../target/release/libnameparser_ffi.so</nameparser.ffi.lib>
      </properties>
    </profile>
  </profiles>
</project>
